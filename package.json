{
  "name": "department360-academic-dashboard",
  "version": "1.0.0",
  "description": "Enterprise Academic Management System for Department360",
  "main": "src/index.ts",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc --noEmitOnError false || true",
    "start": "node dist/index.js",
    "vercel-build": "npm run build && npx prisma generate",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset",
    "generate": "prisma generate",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.ts\"",
    "clean": "rm -rf dist node_modules .next",
    "deploy": "bash scripts/deploy.sh"
  },
  "keywords": [
    "academic",
    "erp",
    "dashboard",
    "education",
    "management"
  ],
  "author": "Department360",
  "license": "MIT",
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@microsoft/microsoft-graph-types": "^2.43.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^5.13.0",
    "@prisma/client": "^5.0.0",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.0",
    "class-validator": "^0.14.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.0",
    "lodash": "^4.17.21",
    "morgan": "^1.10.0",
    "pg": "^8.11.0",
    "react": "^18.2.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@ant-design/icons": "^6.2.5",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.6",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "antd": "^6.4.3",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "multer": "^2.1.1",
    "prettier": "^3.1.1",
    "prisma": "^5.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
