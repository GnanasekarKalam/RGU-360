# Department360 Academic Dashboard - Environment Configuration Template
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env.local in the project root
# 2. Update all marked values (marked with "your-" or specific instructions)
# 3. For local development, see LOCAL DEVELOPMENT SETUP section below
# 4. Never commit .env.local to version control
# 5. Use different values for production

# ============================================
# LOCAL DEVELOPMENT SETUP
# ============================================
# For quick local setup, use these defaults:
# - Database: PostgreSQL on localhost:5432
# - User: postgres / Password: postgres
# - Database name: department360_dev
# 
# To create database:
#   createdb -U postgres department360_dev
#
# Or use Docker:
#   docker run -d --name postgres-dev \
#     -e POSTGRES_PASSWORD=postgres \
#     -e POSTGRES_DB=department360_dev \
#     -p 5432:5432 \
#     postgres:15

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/department360_dev"

# ============================================
# AUTHENTICATION & JWT
# ============================================
# JWT signing keys - Must be at least 32 characters for security
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production-min-32-chars"

# JWT token expiry times
JWT_EXPIRY="24h"
JWT_REFRESH_EXPIRY="7d"

# ============================================
# NEXTAUTH CONFIGURATION
# ============================================
# NextAuth secret for session encryption
NEXTAUTH_SECRET="your-nextauth-secret-change-this-in-production-min-32-chars"

# NextAuth URL - Must match your application URL
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# APPLICATION SETTINGS
# ============================================
# Environment type
NODE_ENV="development"  # development, staging, production

# Server ports
PORT=5000
API_PORT=5000

# URLs
API_URL="http://localhost:5000"
FRONTEND_URL="http://localhost:3000"

# Logging level
LOG_LEVEL="debug"  # debug, info, warn, error

# ============================================
# RATE LIMITING
# ============================================
# Enable/disable rate limiting
RATE_LIMIT_ENABLED=true

# Rate limit window in milliseconds (15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# SESSION CONFIGURATION
# ============================================
# Session timeout in milliseconds (1 hour)
SESSION_TIMEOUT_MS=3600000

# Session refresh interval (30 minutes)
SESSION_REFRESH_INTERVAL_MS=1800000

# Multi-Factor Authentication
MFA_ENABLED=false
MFA_TIMEOUT_MS=300000

# ============================================
# MICROSOFT GRAPH / ONEDRIVE INTEGRATION
# ============================================
# Enable Graph API integration
GRAPH_API_ENABLED=false

# Get these from Azure AD / Microsoft Entra:
# https://portal.azure.com -> Azure AD -> App registrations
ONEDRIVE_CLIENT_ID="your-client-id-here"
ONEDRIVE_CLIENT_SECRET="your-client-secret-here"
ONEDRIVE_TENANT_ID="common"
ONEDRIVE_REDIRECT_URI="http://localhost:5000/auth/graph/callback"

# OneDrive storage path for reports
ONEDRIVE_STORAGE_PATH="/Department360/Reports"

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
# Enable file uploads
UPLOAD_ENABLED=true

# Local upload directory
UPLOAD_PATH="./uploads"

# Maximum file size in bytes (50MB)
UPLOAD_MAX_SIZE=52428800

# Allowed file types (comma-separated)
UPLOAD_ALLOWED_TYPES="pdf,doc,docx,xls,xlsx,jpg,jpeg,png,zip"

# ============================================
# EMAIL CONFIGURATION
# ============================================
# Enable email notifications
EMAIL_ENABLED=false

# SMTP configuration
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-specific-password"
EMAIL_FROM="noreply@department360.local"
EMAIL_ADMIN_CC="admin@rathinam.in"

# To use Gmail:
# 1. Enable 2-Factor Authentication
# 2. Generate App-specific password
# 3. Use app password in EMAIL_PASS

# ============================================
# AUDIT & LOGGING
# ============================================
# Enable audit trail logging
AUDIT_LOGGING_ENABLED=true

# Audit log retention period
AUDIT_LOG_RETENTION_DAYS=365

# Mask sensitive data in logs
SENSITIVE_DATA_MASKING_ENABLED=true

# ============================================
# FEATURE FLAGS
# ============================================
# Enable/disable features
FEATURE_TASK_MANAGEMENT=true
FEATURE_ACCREDITATION=true
FEATURE_REPORTING=true
FEATURE_GRAPH_INTEGRATION=false
FEATURE_MFA=false
FEATURE_ADVANCED_ANALYTICS=true

# ============================================
# TESTING CONFIGURATION
# ============================================
# Seed database with test data on startup
SEED_DATABASE_ON_START=false

# Use mock data instead of real data
USE_MOCK_DATA=true

# ============================================
# PRODUCTION CONSIDERATIONS
# ============================================
# For production deployment:
# 1. Use strong, random values for all secrets
# 2. Use managed database service (AWS RDS, Azure Database, etc.)
# 3. Enable HTTPS (NEXTAUTH_URL should be https://)
# 4. Set NODE_ENV=production
# 5. Disable debug logging
# 6. Enable all security features (MFA, etc.)
# 7. Use external email service (SendGrid, AWS SES, etc.)
# 8. Enable Graph API integration for file storage
# 9. Use environment-specific values in CI/CD pipeline
# 10. Rotate secrets regularly
