// Academic Department360 Dashboard - Prisma Schema
// Database: PostgreSQL
// Generated for Academic Management System

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// CORE MODELS
// ============================================================================

/// User model - Central user account for all system users
model User {
  id                    String      @id @default(cuid())
  email                 String      @unique
  passwordHash          String
  firstName             String
  lastName              String
  middleName            String?
  dateOfBirth           DateTime?   @db.Date

  // Contact Information
  phoneNumber           String?
  mobileNumber          String?
  addressLine1          String?
  addressLine2          String?
  city                  String?
  state                 String?
  zipCode               String?
  country               String?

  // Account Status
  status                UserStatus  @default(ACTIVE)
  isMfaEnabled          Boolean     @default(false)
  mfaMethod             MfaMethod?  @default(TOTP)

  // Timestamps
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  lastLoginAt           DateTime?
  passwordChangedAt     DateTime?
  deletedAt             DateTime?

  // Relations
  roles                 UserRole[]
  faculties             Faculty[]   @relation("user")
  students              Student[]   @relation("user")
  adminOperations       AdminOperation[]
  workflowsInitiated    Workflow[]  @relation("initiated")
  workflowsCompleted    Workflow[]  @relation("completed")
  approvalsPending      WorkflowApproval[] @relation("assigned")
  approvalsReassigned   WorkflowApproval[] @relation("reassigned")
  approvalsEscalated    WorkflowApproval[] @relation("escalated")
  auditLogs             AuditLog[]
  
  // Grade Relations - using Faculty model instead
  enrollmentCreated     Enrollment[] @relation("createdBy")
  enrollmentModified    Enrollment[] @relation("modifiedBy")
  
  // Task Management Relations
  assignedTasks         TaskAssignment[] @relation("assignedTasks")
  groupMembers          TaskGroupMember[] @relation("groupMembers")
  submittedEvidence     TaskEvidence[] @relation("submittedEvidence")
  verifiedEvidence      TaskEvidence[] @relation("verifiedEvidence")
  taskComments          TaskComment[] @relation("taskComments")
  notifications         TaskNotification[] @relation("notifications")
  escalatedTasks        TaskEscalation[] @relation("escalatedTasks")
  receivedEscalations   TaskEscalation[] @relation("receivedEscalations")
  approvingTasks        TaskApproval[] @relation("approvingTasks")
  escalationLevel1      TaskEscalationMatrix[] @relation("escalationLevel1")
  escalationLevel2      TaskEscalationMatrix[] @relation("escalationLevel2")
  escalationLevel3      TaskEscalationMatrix[] @relation("escalationLevel3")
  
  // Accreditation Relations
  assignedRoles         UserRole[]  @relation("assignedRoles")

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ARCHIVED
}

enum MfaMethod {
  TOTP
  SMS
  EMAIL
  AUTHENTICATOR
}

/// User Roles - Links users to roles with optional department scope
model UserRole {
  id              String    @id @default(cuid())
  userId          String
  roleId          String
  departmentId    String?
  assignedById    String?
  assignedAt      DateTime  @default(now())
  expiresAt       DateTime?
  isPrimary       Boolean   @default(false)

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            Role      @relation(fields: [roleId], references: [id])
  department      Department? @relation(fields: [departmentId], references: [id])
  assignedBy      User?     @relation("assignedRoles", fields: [assignedById], references: [id])

  @@unique([userId, roleId, departmentId])
  @@index([userId])
  @@index([roleId])
  @@index([departmentId])
}

// ============================================================================
// FACULTY & STUDENT MODELS
// ============================================================================

/// Faculty model - Extended information for faculty members
model Faculty {
  id                      String      @id @default(cuid())
  userId                  String      @unique
  departmentId            String
  employeeId              String      @unique
  title                   String?
  specialization          String?
  academicDegree          String?
  degreeInstitution       String?

  // Employment
  employmentStatus        EmploymentStatus @default(FULL_TIME)
  hireDate                DateTime?   @db.Date
  tenureStatus            TenureStatus @default(NON_TENURE_TRACK)
  tenureDate              DateTime?   @db.Date

  // Office Information
  officeLocation          String?
  officePhone             String?
  officeHours             String?     // JSON formatted

  // Performance
  performanceRating       Decimal?    @db.Decimal(3, 2)
  teachingEffectivenessScore Decimal? @db.Decimal(3, 2)
  lastEvaluationDate      DateTime?   @db.Date

  // Financial (Encrypted)
  salaryAmount            Decimal?    @db.Decimal(10, 2)
  salaryCurrency          String?     @default("USD")

  // Status
  isActive                Boolean     @default(true)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  user                    User        @relation("user", fields: [userId], references: [id], onDelete: Restrict)
  department              Department  @relation(fields: [departmentId], references: [id])
  classes                 Class[]
  gradeSubmitted          Grade[]     @relation("submittedByFaculty")
  gradeApproved           Grade[]     @relation("approvedByFaculty")
  advisedStudents         Student[]
  gradeAppealsFaculty     GradeAppeal[] @relation("facultyReviewerFaculty")
  gradeAppealsDept        GradeAppeal[] @relation("deptReviewerFaculty")
  departmentHeadOf        Department? @relation("head")
  
  // Faculty Master Details
  qualifications          FacultyQualification[]
  publications            FacultyPublication[]
  fdpPrograms             FacultyFDP[]
  seminars                FacultySeminar[]
  phdCandidates           FacultyPhd[]
  skills                  FacultySkill[]
  evidenceItems           FacultyEvidence[]
  
  // Tutoring
  tutorWards              StudentTutorWard[]  @relation("tutorWards")
  
  // Accreditation Relations
  accreditationMappings   AccreditationCriteriaMapping[] @relation("accreditationMappingFaculty")
  accreditationFacultyMap AccreditationFacultyMapping[]  @relation("accreditationFacultyMap")

  @@index([departmentId])
  @@index([employmentStatus])
  @@index([isActive])
}

enum EmploymentStatus {
  FULL_TIME
  PART_TIME
  ADJUNCT
  VISITING
}

enum TenureStatus {
  TENURED
  TENURE_TRACK
  NON_TENURE_TRACK
}

/// Student model - Extended information for students
model Student {
  id                      String      @id @default(cuid())
  userId                  String      @unique
  studentId               String      @unique
  degreeProgram           String      // Program ID or name
  majorId                 String
  minorId                 String?
  concentrationId         String?

  // Enrollment Status
  enrollmentStatus        EnrollmentStatus @default(ENROLLED)
  enrollmentDate          DateTime    @db.Date
  expectedGraduationDate  DateTime?   @db.Date
  graduationDate          DateTime?   @db.Date

  // Academic Standing
  currentGpa              Decimal?    @db.Decimal(4, 3)
  cumulativeGpa           Decimal?    @db.Decimal(4, 3)
  academicStanding        AcademicStanding @default(GOOD)
  creditsEarned           Int         @default(0)
  creditsRequired         Int?

  // Contact Information
  permanentAddressId      String?
  currentAddressId        String?
  emergencyContactName    String?
  emergencyContactPhone   String?
  emergencyContactRelation String?

  // Financial Hold
  hasFinancialHold        Boolean     @default(false)

  // Advisor
  primaryAdvisorId        String?

  // Timestamps
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  user                    User        @relation("user", fields: [userId], references: [id], onDelete: Restrict)
  primaryAdvisor          Faculty?    @relation(fields: [primaryAdvisorId], references: [id])
  enrollments             Enrollment[]
  grades                  Grade[]
  gradeAppeals            GradeAppeal[]
  
  // Student Master Details
  parents                 StudentParent[]
  academicRecords         StudentAcademicRecord[]
  fees                    StudentFee[]
  tutorWards              StudentTutorWard[]
  
  // Accreditation Relations
  accreditationMappings   AccreditationCriteriaMapping[] @relation("accreditationMappingStudent")
  accreditationStudentMap AccreditationStudentMapping[]  @relation("accreditationStudentMap")

  @@index([enrollmentStatus])
  @@index([academicStanding])
  @@index([primaryAdvisorId])
}

enum EnrollmentStatus {
  ENROLLED
  LEAVE_OF_ABSENCE
  GRADUATED
  WITHDRAWN
  SUSPENDED
}

enum AcademicStanding {
  GOOD
  WARNING
  PROBATION
  SUSPENSION
}

/// Admin Operation - Administrative staff assignments
model AdminOperation {
  id                String    @id @default(cuid())
  userId            String
  departmentId      String?
  operationScope    String?   // JSON formatted
  startDate         DateTime  @default(now())
  endDate           DateTime?

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================================
// ACADEMIC STRUCTURE MODELS
// ============================================================================

/// Department model - Academic departments
model Department {
  id                      String      @id @default(cuid())
  code                    String      @unique
  name                    String      @unique
  fullName                String?
  description             String?

  // Leadership
  departmentHeadId        String?     @unique
  phone                   String?
  email                   String?
  officeLocation          String?

  // Configuration
  isActive                Boolean     @default(true)
  budgetAllocation        Decimal?    @db.Decimal(12, 2)
  academicCalendarId      String?

  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  departmentHead          Faculty?    @relation("head", fields: [departmentHeadId], references: [id], onDelete: SetNull)
  faculty                 Faculty[]
  programs                Program[]
  courses                 Course[]
  userRoles               UserRole[]

  @@index([code])
  @@index([isActive])
}

/// Program model - Degree programs
model Program {
  id                      String      @id @default(cuid())
  departmentId            String
  code                    String
  name                    String
  degreeType              DegreeType  @default(BACHELOR)
  description             String?

  // Academic Requirements
  totalCreditsRequired    Int?
  minimumGpa              Decimal     @db.Decimal(3, 2) @default(2.0)

  // Accreditation
  accreditationStatus     String?
  accreditationBody       String?
  accreditationExpiry     DateTime?   @db.Date

  // Status
  isActive                Boolean     @default(true)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  department              Department  @relation(fields: [departmentId], references: [id])
  courses                 CourseProgram[]

  @@unique([departmentId, code])
  @@index([isActive])
}

enum DegreeType {
  BACHELOR
  MASTER
  PHD
  CERTIFICATE
}

/// Course model - Course definitions
model Course {
  id                      String      @id @default(cuid())
  departmentId            String
  courseCode              String
  courseNumber            Int
  title                   String
  description             String?

  // Academic Details
  creditHours             Int         @default(3)
  contactHours            Int?
  labHours                Int?
  isLabCourse             Boolean     @default(false)

  // Prerequisites
  prerequisiteCourseId    String?
  prerequisiteGradeRequired String?
  corequisiteCourseId     String?

  // Curriculum
  isGeneralEducation      Boolean     @default(false)

  // Learning Outcomes & Assessment
  learningOutcomes        String?     // JSON format
  assessmentMethods       String?     // JSON format

  // Enrollment
  maxEnrollment           Int         @default(40)
  minEnrollment           Int         @default(10)

  // Status
  isActive                Boolean     @default(true)
  isOnline                Boolean     @default(false)

  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  department              Department  @relation(fields: [departmentId], references: [id])
  prerequisiteCourse      Course?     @relation("prerequisite", fields: [prerequisiteCourseId], references: [id])
  prerequisiteFor         Course[]    @relation("prerequisite")
  corequisiteCourse       Course?     @relation("corequisite", fields: [corequisiteCourseId], references: [id])
  corequisiteFor          Course[]    @relation("corequisite")
  programs                CourseProgram[]
  classes                 Class[]

  @@unique([departmentId, courseCode])
  @@index([isActive])
  @@index([prerequisiteCourseId])
}

model CourseProgram {
  id          String    @id @default(cuid())
  courseId    String
  programId   String
  isRequired  Boolean   @default(true)
  sequenceOrder Int?

  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  program     Program   @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([courseId, programId])
}

/// Class model - Course section instances
model Class {
  id                      String      @id @default(cuid())
  courseId                String
  instructorId            String
  semesterId              String

  // Schedule
  sectionNumber           Int         @default(1)
  dayOfWeek               String?     // Monday, Tuesday, etc.
  startTime               DateTime?   @db.Time
  endTime                 DateTime?   @db.Time
  location                String?     // Building and room

  // Capacity
  enrollmentCapacity      Int
  currentEnrollment       Int         @default(0)
  waitlistCount           Int         @default(0)

  // Mode
  deliveryMode            DeliveryMode @default(IN_PERSON)

  // Grading
  gradingSchemeId         String?

  // Status
  isActive                Boolean     @default(true)
  isFull                  Boolean     @default(false)

  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  course                  Course      @relation(fields: [courseId], references: [id])
  instructor              Faculty     @relation(fields: [instructorId], references: [id])
  semester                Semester    @relation(fields: [semesterId], references: [id])
  enrollments             Enrollment[]
  grades                  Grade[]

  @@unique([courseId, semesterId, sectionNumber])
  @@index([instructorId])
  @@index([semesterId])
}

enum DeliveryMode {
  IN_PERSON
  ONLINE
  HYBRID
}

/// Enrollment model - Student course enrollments
model Enrollment {
  id                      String      @id @default(cuid())
  studentId               String
  classId                 String
  semesterId              String

  // Status
  enrollmentStatus        EnrollmentStatusEnum @default(ENROLLED)
  enrollmentDate          DateTime    @default(now())
  dropDate                DateTime?

  // Grade
  gradeId                 String?
  gradeLetter             String?
  gradePoints             Decimal?    @db.Decimal(3, 2)
  isGradeFinal            Boolean     @default(false)
  gradePostedDate         DateTime?

  // Attendance
  attendanceCount         Int         @default(0)
  absenceCount            Int         @default(0)

  // Transcript
  includeInGpa            Boolean     @default(true)
  transcriptStatus        TranscriptStatus @default(PENDING)

  // Audit Trail
  createdById             String?
  modifiedById            String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  student                 Student     @relation(fields: [studentId], references: [id])
  class                   Class       @relation(fields: [classId], references: [id])
  semester                Semester    @relation(fields: [semesterId], references: [id])
  grade                   Grade?
  createdBy               User?       @relation("createdBy", fields: [createdById], references: [id])
  modifiedBy              User?       @relation("modifiedBy", fields: [modifiedById], references: [id])

  @@unique([studentId, classId, semesterId])
  @@index([enrollmentStatus])
  @@index([semesterId])
}

enum EnrollmentStatusEnum {
  ENROLLED
  WAITLISTED
  DROPPED
  AUDIT
}

enum TranscriptStatus {
  PENDING
  POSTED
  HELD
}

// ============================================================================
// GRADING MODELS
// ============================================================================

/// Grade model - Student grades
model Grade {
  id                      String      @id @default(cuid())
  enrollmentId            String
  classId                 String
  studentId               String

  // Grade Information
  gradeNumeric            Decimal?    @db.Decimal(5, 2)
  gradeLetter             String?
  gradePoints             Decimal?    @db.Decimal(3, 2)

  // Grading Components
  participationScore      Decimal?    @db.Decimal(5, 2)
  attendanceScore         Decimal?    @db.Decimal(5, 2)
  assignmentScore         Decimal?    @db.Decimal(5, 2)
  midtermScore            Decimal?    @db.Decimal(5, 2)
  finalExamScore          Decimal?    @db.Decimal(5, 2)
  projectScore            Decimal?    @db.Decimal(5, 2)

  // Status
  isDraft                 Boolean     @default(true)
  isApproved              Boolean     @default(false)
  isFinal                 Boolean     @default(false)

  // Submission & Approval
  submittedById           String?
  submittedAt             DateTime?
  approvedById            String?
  approvedAt              DateTime?

  // Comments
  facultyComments         String?
  studentComments         String?

  // Audit
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  enrollment              Enrollment  @relation(fields: [enrollmentId], references: [id])
  class                   Class       @relation(fields: [classId], references: [id])
  student                 Student     @relation(fields: [studentId], references: [id])
  
  @@unique([enrollmentId])
  submittedBy             Faculty?    @relation("submittedByFaculty", fields: [submittedById], references: [id])
  approvedBy              Faculty?    @relation("approvedByFaculty", fields: [approvedById], references: [id])
  gradeAppeal             GradeAppeal[] @relation("originalGrade")
  outcomeGradeAppeal      GradeAppeal[] @relation("outcomeGrade")

  @@index([studentId])
  @@index([enrollmentId])
  @@index([isApproved])
  @@index([submittedAt])
}

/// Grade Appeal model - Student grade appeal process
model GradeAppeal {
  id                      String      @id @default(cuid())
  enrollmentId            String
  studentId               String
  gradeId                 String

  // Appeal Details
  appealReason            String
  appealDate              DateTime    @default(now())

  // Status
  appealStatus            AppealStatus @default(SUBMITTED)

  // Faculty Response
  facultyResponse         String?
  facultyResponseDate     DateTime?
  facultyReviewerId       String?

  // Department Head Review
  departmentReviewNotes   String?
  departmentReviewerId    String?
  departmentReviewDate    DateTime?

  // Outcome
  outcomeGradeId          String?
  resolutionDate          DateTime?

  // Audit
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  student                 Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  grade                   Grade       @relation("originalGrade", fields: [gradeId], references: [id])
  facultyReviewer         Faculty?    @relation("facultyReviewerFaculty", fields: [facultyReviewerId], references: [id])
  departmentReviewer      Faculty?    @relation("deptReviewerFaculty", fields: [departmentReviewerId], references: [id])
  outcomeGrade            Grade?      @relation("outcomeGrade", fields: [outcomeGradeId], references: [id])

  @@index([studentId])
  @@index([appealStatus])
  @@index([appealDate])
}

enum AppealStatus {
  SUBMITTED
  IN_REVIEW
  APPROVED
  DENIED
  ESCALATED
}

// ============================================================================
// WORKFLOW & APPROVAL MODELS
// ============================================================================

/// Workflow model - Base workflow tracking
model Workflow {
  id                      String      @id @default(cuid())
  workflowType            WorkflowType
  status                  WorkflowStatus @default(DRAFT)

  // Related Resource
  relatedResourceType     String?
  relatedResourceId       String?

  // Initiator
  initiatedById           String
  initiatedAt             DateTime    @default(now())

  // Completion
  completedById           String?
  completedAt             DateTime?

  // Metadata
  data                    Json?       // Flexible workflow-specific data
  comments                String?

  // Timeline
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  initiatedBy             User        @relation("initiated", fields: [initiatedById], references: [id])
  completedBy             User?       @relation("completed", fields: [completedById], references: [id])
  approvals               WorkflowApproval[]

  @@index([workflowType])
  @@index([status])
  @@index([initiatedAt])
}

enum WorkflowType {
  GRADE_SUBMISSION
  COURSE_ADDITION
  GRADE_APPEAL
  LEAVE_REQUEST
  CURRICULUM_CHANGE
  ACADEMIC_STANDING_CHANGE
}

enum WorkflowStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

/// WorkflowApproval model - Individual approval steps in workflow
model WorkflowApproval {
  id                      String      @id @default(cuid())
  workflowId              String
  approvalLevel           Int

  // Approver
  assignedToId            String
  assignedAt              DateTime    @default(now())

  // Status
  approvalStatus          ApprovalStatus @default(PENDING)

  // Response
  responseDate            DateTime?
  comments                String?

  // Reassignment
  reassignedToId          String?
  reassignmentReason      String?
  reassignmentDate        DateTime?

  // Escalation
  escalationReason        String?
  escalatedToId           String?
  escalationDate          DateTime?
  escalationLevel         Int?

  // Timeline
  dueDate                 DateTime?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  workflow                Workflow    @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  assignedTo              User        @relation("assigned", fields: [assignedToId], references: [id])
  reassignedTo            User?       @relation("reassigned", fields: [reassignedToId], references: [id])
  escalatedTo             User?       @relation("escalated", fields: [escalatedToId], references: [id])

  @@unique([workflowId, approvalLevel])
  @@index([assignedToId])
  @@index([approvalStatus])
  @@index([dueDate])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
  REASSIGNED
}

// ============================================================================
// AUDIT & LOGGING MODELS
// ============================================================================

/// AuditLog model - Comprehensive audit trail for FERPA compliance
model AuditLog {
  id                      String      @id @default(cuid())
  userId                  String?
  action                  String
  resourceType            String?
  resourceId              String?

  // Change Details
  oldValues               Json?
  newValues               Json?

  // Request Details
  ipAddress               String?
  userAgent               String?

  // Status
  status                  String?
  errorMessage            String?

  // FERPA Tracking
  ferpaProtected          Boolean     @default(false)
  studentId               String?

  // Severity
  severity                Severity    @default(INFO)

  // Retention
  retentionUntil          DateTime?   @db.Date

  // Timestamp
  createdAt               DateTime    @default(now())

  // Relations
  user                    User?       @relation(fields: [userId], references: [id])
  // student removed - Student doesn't have back-relation

  @@index([userId])
  @@index([createdAt])
  @@index([resourceType, resourceId])
  @@index([ferpaProtected])
  @@index([severity])
}

enum Severity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

// ============================================================================
// REFERENCE/LOOKUP MODELS
// ============================================================================

/// Semester model - Academic terms/semesters
model Semester {
  id                      String      @id @default(cuid())
  code                    String      @unique
  name                    String
  academicYear            Int
  season                  Season

  startDate               DateTime    @db.Date
  endDate                 DateTime    @db.Date
  registrationStart       DateTime?   @db.Date
  registrationEnd         DateTime?   @db.Date
  addDropDeadline         DateTime?   @db.Date
  withdrawalDeadline      DateTime?   @db.Date
  gradesDueDate           DateTime?   @db.Date

  isActive                Boolean     @default(false)
  createdAt               DateTime    @default(now())

  // Relations
  classes                 Class[]
  enrollments             Enrollment[]

  @@index([academicYear])
  @@index([isActive])
}

enum Season {
  SPRING
  SUMMER
  FALL
  WINTER
}

/// Role model - System and custom roles
model Role {
  id                      String      @id @default(cuid())
  name                    String      @unique
  description             String?
  isSystemRole            Boolean     @default(false)
  isActive                Boolean     @default(true)

  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  userRoles               UserRole[]
  permissions             RolePermission[]

  @@index([name])
  @@index([isActive])
}

/// Permission model - System permissions
model Permission {
  id                      String      @id @default(cuid())
  name                    String      @unique
  description             String?
  resource                String?
  action                  String?

  createdAt               DateTime    @default(now())

  // Relations
  roles                   RolePermission[]

  @@unique([resource, action])
}

/// RolePermission model - Maps permissions to roles
model RolePermission {
  id                      String      @id @default(cuid())
  roleId                  String
  permissionId            String

  createdAt               DateTime    @default(now())

  // Relations
  role                    Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission              Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

// ============================================================================
// ACCREDITATION & EVIDENCE MODELS
// ============================================================================

/// Accreditation model - Program accreditation tracking
model Accreditation {
  id                      String      @id @default(cuid())
  programId               String
  accreditationBody       String
  status                  AccreditationStatus @default(PENDING)
  
  expiryDate              DateTime    @db.Date
  lastReviewDate          DateTime?   @db.Date
  nextReviewDate          DateTime?   @db.Date
  
  documentUrl             String?
  reviewNotes             String?
  
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  evidenceItems           AccreditationEvidence[]

  @@index([status])
  @@index([expiryDate])
}

enum AccreditationStatus {
  PENDING
  ACTIVE
  WARNING
  EXPIRED
  UNDER_REVIEW
}

/// AccreditationEvidence model - Evidence for accreditation
