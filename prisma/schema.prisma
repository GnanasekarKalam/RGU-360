  @@index([studentId])
  @@index([academicYear])
  @@index([academicStanding])
}

/// StudentFee model - Fee structure and payment tracking
model StudentFee {
  id                      String      @id @default(cuid())
  studentId               String
  semester                String
  academicYear            String
  
  feeCategory             String      // TUITION, HOSTEL, TRANSPORTATION, ACTIVITY, LIBRARY, LABORATORY, OTHER
  feeDescription          String?
  
  totalFeeAmount          Decimal     @db.Decimal(10, 2)
  dueDate                 DateTime    @db.Date
  
  paidAmount              Decimal     @db.Decimal(10, 2) @default(0)
  balance                 Decimal     @db.Decimal(10, 2)
  
  paymentStatus           String      @default("PENDING") // PENDING, PARTIAL_PAID, PAID, OVERDUE, WAIVED, EXEMPTED
  lastPaymentDate         DateTime?
  lastPaymentAmount       Decimal?    @db.Decimal(10, 2)
  
  installments            Int         @default(1)
  installmentsPaid        Int         @default(0)
  
  remarks                 String?
  
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  student                 Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments                StudentFeePayment[]

  @@index([studentId])
  @@index([semester])
  @@index([academicYear])
  @@index([feeCategory])
  @@index([paymentStatus])
  @@index([dueDate])
}

/// StudentFeePayment model - Individual fee payment records
model StudentFeePayment {
  id                      String      @id @default(cuid())
  studentFeeId            String
  
  paymentAmount           Decimal     @db.Decimal(10, 2)
  paymentDate             DateTime
  
  transactionId           String?
  paymentMethod           String?     // CASH, CHEQUE, BANK_TRANSFER, CREDIT_CARD, ONLINE
  
  bankDetails             String?     // Bank name, branch, etc.
  chequeNumber            String?
  chequeDate              DateTime?   @db.Date
  
  receiptNumber           String?
  receiptUrl              String?
  
  remarks                 String?
  processedBy             String?
  
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  fee                     StudentFee  @relation(fields: [studentFeeId], references: [id], onDelete: Cascade)

  @@index([studentFeeId])
  @@index([paymentDate])
  @@index([transactionId])
}

/// StudentTutorWard model - Student tutoring/mentoring assignment
model StudentTutorWard {
  id                      String      @id @default(cuid())
  studentId               String
  tutorId                 String      // Reference to Faculty
  
  assignmentDate          DateTime    @default(now())
  startDate               DateTime    @db.Date
  endDate                 DateTime?   @db.Date
  
  status                  String      @default("ACTIVE") // ACTIVE, INACTIVE, COMPLETED, TERMINATED, PAUSED
  
  assignmentReason        String?     // Academic support, skill development, counseling, etc.
  mentorshipPlan          String?     // JSON format - outline of mentorship goals
  
  frequencyOfMeeting      Int?        // Times per week/month
  meetingDuration         Int?        // Minutes
  
  lastMeetingDate         DateTime?
  nextMeetingDate         DateTime?
  
  performanceNotes        String?
  
  isActive                Boolean     @default(true)
  
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  student                 Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tutor                   Faculty     @relation("tutorWards", fields: [tutorId], references: [id], onDelete: Restrict)
  meetingRecords          StudentMeetingRecord[]

  @@unique([studentId, tutorId])
  @@index([studentId])
  @@index([tutorId])
  @@index([status])
  @@index([startDate])
}

/// StudentMeetingRecord model - Student-Tutor meeting logs
model StudentMeetingRecord {
  id                      String      @id @default(cuid())
  tutorWardId             String
  
  meetingDate             DateTime
  duration                Int         // Minutes
  
  topics                  String[]    @default([])
  notes                   String?
  
  studentProgress         String?     // Feedback on student
  discussionPoints        String?     // Topics discussed
  
  nextActionItems         String?
  nextMeetingScheduled    DateTime?
  
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Relations
  tutorWard               StudentTutorWard @relation(fields: [tutorWardId], references: [id], onDelete: Cascade)

  @@index([tutorWardId])
  @@index([meetingDate])
}

