// ============================================================================
// TASK MANAGEMENT MODELS - See earlier Task model definition above
// ============================================================================

/// TaskAssignment model - Individual task assignments
model TaskAssignment {
  id                      String      @id @default(cuid())
  taskId                  String
  assignedToId            String
  assignedToType          String      // FACULTY, STUDENT, GROUP
  
  // Assignment Details
  assignmentDate          DateTime    @default(now())
  acceptanceDate          DateTime?
  completionDate          DateTime?
  
  // Status
  assignmentStatus        String      @default("PENDING") // PENDING, ACCEPTED, REJECTED, IN_PROGRESS, COMPLETED, OVERDUE
  acceptanceStatus        String      @default("PENDING") // PENDING, ACCEPTED, DECLINED
  
  // Progress
  progressPercentage      Int         @default(0)
  progressNotes           String?
  
  // Deadline
  individualDueDate       DateTime?   @db.Date
  reminderSent            Boolean     @default(false)
  
  // Relations
  // task removed - Task doesn't have back-relation
  assignedTo              User        @relation("assignedTasks", fields: [assignedToId], references: [id])
  
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  
  @@unique([taskId, assignedToId])
  @@index([taskId])
  @@index([assignedToId])
  @@index([assignmentStatus])
}

/// TaskGroup model - Group of tasks or recipients
model TaskGroup {
  id                      String      @id @default(cuid())
  name                    String
  description             String?
  groupType               String      // FACULTY_GROUP, STUDENT_GROUP, CLASS_GROUP, DEPARTMENT_GROUP
  
  // Details
  departmentId            String?
  createdById             String
  
  // Configuration
  isActive                Boolean     @default(true)
  
  // Relations
  members                 TaskGroupMember[]
  assignments             TaskGroupAssignment[]
  
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  
  @@index([createdById])
  @@index([groupType])
  @@index([isActive])
}

/// TaskGroupMember model - Members of task groups
model TaskGroupMember {
  id                      String      @id @default(cuid())
  groupId                 String
  memberId                String
  memberType              String      // FACULTY, STUDENT
  
  // Relations
  group                   TaskGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  member                  User        @relation("groupMembers", fields: [memberId], references: [id])
  
  createdAt               DateTime    @default(now())
  
  @@unique([groupId, memberId])
  @@index([groupId])
  @@index([memberId])
}

/// TaskGroupAssignment model - Assigning tasks to groups
model TaskGroupAssignment {
  id                      String      @id @default(cuid())
  taskId                  String
  groupId                 String
  
  // Status
  assignmentStatus        String      @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  
  // Tracking
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  
  // Relations
  // task removed - Task doesn't have back-relation
  group                   TaskGroup   @relation(fields: [groupId], references: [id])
  
  @@unique([taskId, groupId])
  @@index([taskId])
  @@index([groupId])
}

/// TaskApproval model - Approval workflow
model TaskApproval {
  id                      String      @id @default(cuid())
  taskId                  String
  approverUserId          String
  
  // Approval Details
  approvalRequired        Boolean     @default(true)
  approvalType            String      @default("AUTOMATIC") // AUTOMATIC, MANUAL, CONDITIONAL
  approvalLevel           Int         @default(1)
  
  // Status
  approvalStatus          String      @default("PENDING") // PENDING, APPROVED, REJECTED, AWAITING_REVISION
  approvedAt              DateTime?
  
  // Feedback
  approvalComments        String?
  rejectionReason         String?
  
  // Relations
  // task removed - Task doesn't have back-relation
  approver                User        @relation("approvingTasks", fields: [approverUserId], references: [id])
  
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  
  @@index([taskId])
  @@index([approverUserId])
  @@index([approvalStatus])
}

/// TaskEvidence model - Evidence/submissions for tasks
model TaskEvidence {
  id                      String      @id @default(cuid())
  taskId                  String
  submittedById           String
  
  // Evidence Details
  title                   String
  description             String?
  evidenceType            String      // FILE, URL, TEXT, IMAGE, VIDEO, LINK
  
  // Files/Links
  fileUrl                 String?
  fileName                String?
  fileSize                Int?        // In bytes
  fileType                String?
  
  // Link/Text Evidence
  externalLink            String?
  textContent             String?
  
  // Metadata
  uploadedAt              DateTime    @default(now())
  
  // Verification
  isVerified              Boolean     @default(false)
  verifiedBy              String?
  verifiedAt              DateTime?
  verificationComments    String?
  
  // Relations
  // task removed - Task doesn't have back-relation
  submittedBy             User        @relation("submittedEvidence", fields: [submittedById], references: [id])
  verifier                User?       @relation("verifiedEvidence", fields: [verifiedBy], references: [id])
  
  @@index([taskId])
  @@index([submittedById])
  @@index([isVerified])
}

/// TaskComment model - Comments and discussions
model TaskComment {
  id                      String      @id @default(cuid())
  taskId                  String
  commentedById           String
  
  // Comment Details
  content                 String
  commentType             String      @default("GENERAL") // GENERAL, UPDATE, FEEDBACK, QUESTION
  
  // Relations
  // task removed - Task doesn't have back-relation
  commentedBy             User        @relation("taskComments", fields: [commentedById], references: [id])
  
  // Timestamps
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  
  @@index([taskId])
  @@index([commentedById])
}

/// TaskNotification model - Notifications for tasks
model TaskNotification {
  id                      String      @id @default(cuid())
  taskId                  String
  recipientId             String
  
  // Notification Details
  title                   String
  message                 String
  notificationType        String      // ASSIGNMENT, APPROVAL, COMPLETION, OVERDUE, ESCALATION, COMMENT
  
  // Status
  isRead                  Boolean     @default(false)
  readAt                  DateTime?
  
  // Relations
  // task removed - Task doesn't have back-relation
  recipient               User        @relation("notifications", fields: [recipientId], references: [id])
  
  createdAt               DateTime    @default(now())
  
  @@index([taskId])
  @@index([recipientId])
  @@index([isRead])
}

/// TaskEscalation model - Escalation tracking
model TaskEscalation {
  id                      String      @id @default(cuid())
  taskId                  String
  escalatedById           String
  
  // Escalation Details
  escalationReason        String
  escalationLevel         Int         @default(1) // 1, 2, 3, etc.
  targetUserId            String?     // Next level escalation target
  
  // Status
  escalationStatus        String      @default("PENDING") // PENDING, ACKNOWLEDGED, RESOLVED, REJECTED
  resolvedAt              DateTime?
  
  // Resolution
  resolutionNotes         String?
  
  // Relations
  // task removed - Task doesn't have back-relation
  escalatedBy             User        @relation("escalatedTasks", fields: [escalatedById], references: [id])
  targetUser              User?       @relation("receivedEscalations", fields: [targetUserId], references: [id])
  
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  
  @@index([taskId])
  @@index([escalatedById])
  @@index([escalationStatus])
}

// ============================================================================
// TASK CONFIGURATION MODELS
// ============================================================================

/// TaskEscalationMatrix model - Escalation rules configuration
model TaskEscalationMatrix {
  id                      String      @id @default(cuid())
  
  // Configuration
  taskType                String
  priority                String
  departmentId            String?
  
  // Escalation Rules
  level1UserId            String?     // First escalation level
  level2UserId            String?     // Second escalation level
  level3UserId            String?     // Third escalation level
  
  // Thresholds
  escalateAfterDaysOverdue Int        @default(3)
  escalateOnProgressZero  Boolean     @default(true)
  escalateOnNoUpdate      Int?        // Days without update
  
  // Relations
  level1User              User?       @relation("escalationLevel1", fields: [level1UserId], references: [id])
  level2User              User?       @relation("escalationLevel2", fields: [level2UserId], references: [id])
  level3User              User?       @relation("escalationLevel3", fields: [level3UserId], references: [id])
  
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  
  @@unique([taskType, priority, departmentId])
  @@index([taskType])
}

/// TaskTemplate model - Reusable task templates
model TaskTemplate {
  id                      String      @id @default(cuid())
  
  // Template Details
  name                    String
  description             String?
  
  // Task Configuration
  taskType                String
  priority                String      @default("MEDIUM")
  defaultDuration         Int?        // Days
  
  // Requirements
  requiresApproval        Boolean     @default(false)
  requiresEvidence        Boolean     @default(false)
  
  // Status
  isActive                Boolean     @default(true)
  
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  
  @@index([isActive])
}

// ============================================================================
// ACCREDITATION MODULE
// ============================================================================

/// AccreditationBody model - Accreditation bodies (NBA, NAAC, UGC, AICTE, IQAC)
model AccreditationBody {
  id                      String      @id @default(cuid())
  name                    String      @unique // NBA, NAAC, UGC, AICTE, IQAC
  fullName                String
  description             String?
  websiteUrl              String?
  
  // Relations
  criteria                AccreditationCriteria[]
  
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  
  @@index([name])
}

/// AccreditationCriteria model - Criteria for accreditation
model AccreditationCriteria {
  id                      String      @id @default(cuid())
  bodyId                  String
  criteriaCode            String      // NBA-1.1, NAAC-2.3, etc.
  criteriaTitle           String
  description             String?
  evidenceRequirements    String?
  
  // Relations
  body                    AccreditationBody @relation(fields: [bodyId], references: [id], onDelete: Cascade)
  mappings                AccreditationCriteriaMapping[]
  
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  
  @@unique([bodyId, criteriaCode])
  @@index([bodyId])
  @@index([criteriaCode])
}

/// AccreditationAcademicYear model - Academic year tracking for accreditation
model AccreditationAcademicYear {
  id                      String      @id @default(cuid())
  academicYear            String      @unique // 2025-2026
  startDate               DateTime
  endDate                 DateTime
  isActive                Boolean     @default(false)
  
  // Relations
  mappings                AccreditationCriteriaMapping[]
  
  createdAt               DateTime    @default(now())
  
  @@index([academicYear])
  @@index([isActive])
}

/// AccreditationCriteriaMapping model - Map criteria to faculty/student/department
model AccreditationCriteriaMapping {
  id                      String      @id @default(cuid())
  criteriaId              String
  academicYearId          String?
  facultyId               String?
  studentId               String?
  departmentId            String?
  mappingType             String      // FACULTY, STUDENT, DEPARTMENT, PROGRAM
  description             String?
  
  // Relations
  criteria                AccreditationCriteria @relation(fields: [criteriaId], references: [id], onDelete: Cascade)
  academicYear            AccreditationAcademicYear? @relation(fields: [academicYearId], references: [id])
  faculty                 Faculty?    @relation("accreditationMappingFaculty", fields: [facultyId], references: [id])
  student                 Student?    @relation("accreditationMappingStudent", fields: [studentId], references: [id])
  
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  
  @@index([criteriaId])
  @@index([academicYearId])
  @@index([facultyId])
  @@index([studentId])
  @@index([mappingType])
}

/// AccreditationFacultyMapping model - Track faculty assignments
model AccreditationFacultyMapping {
  id                      String      @id @default(cuid())
  facultyId               String
  academicYear            String
  assignedCriteria        String[]    // Array of criteria codes
  mappingStatus           String      @default("ACTIVE") // ACTIVE, PENDING, COMPLETED
  compliancePercentage    Int         @default(0)
  evidenceCount           Int         @default(0)
  
  // Relations
  faculty                 Faculty     @relation("accreditationFacultyMap", fields: [facultyId], references: [id])
  
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  
  @@unique([facultyId, academicYear])
  @@index([facultyId])
  @@index([academicYear])
  @@index([mappingStatus])
}

/// AccreditationStudentMapping model - Track student assignments
model AccreditationStudentMapping {
  id                      String      @id @default(cuid())
  studentId               String
  academicYear            String
  program                 String
  assignedCriteria        String[]    // Array of criteria codes
  mappingStatus           String      @default("ACTIVE") // ACTIVE, PENDING, COMPLETED
  compliancePercentage    Int         @default(0)
  evidenceCount           Int         @default(0)
  
  // Relations
  student                 Student     @relation("accreditationStudentMap", fields: [studentId], references: [id])
  
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  
  @@unique([studentId, academicYear])
  @@index([studentId])
  @@index([academicYear])
  @@index([mappingStatus])
}

/// AccreditationReport model - Generated reports
model AccreditationReport {
  id                      String      @id @default(cuid())
  reportName              String
  bodyType                String      // NBA, NAAC, UGC, AICTE, IQAC
  academicYear            String
  generatedByUserId       String
  reportFormat            String      @default("PDF") // PDF, EXCEL, JSON
  fileUrl                 String?
  
  // Metrics
  totalCriteria           Int
  mappedCriteria          Int
  evidenceCount           Int
  complianceRate          Int
  
  // Status
  status                  String      @default("DRAFT") // DRAFT, GENERATED, APPROVED, SUBMITTED
  remarks                 String?
  
  // Relations
  // generatedBy removed - User doesn't have back-relation defined
  
  generatedAt             DateTime    @default(now())
  approvedAt              DateTime?
  
  @@index([bodyType])
  @@index([academicYear])
  @@index([status])
  @@index([generatedAt])
}

/// AccreditationAlert model - Missing evidence alerts
model AccreditationAlert {
  id                      String      @id @default(cuid())
  mappingId               String
  alertType               String      // MISSING_EVIDENCE, PENDING_VERIFICATION, EXPIRED_EVIDENCE, INCOMPLETE_MAPPING
  severity                String      // LOW, MEDIUM, HIGH, CRITICAL
  message                 String
  status                  String      @default("ACTIVE") // ACTIVE, RESOLVED, ACKNOWLEDGED
  
  // Resolution
  resolvedByUserId        String?
  resolutionNotes         String?
  
  // Relations
  // mapping removed - AccreditationCriteriaMapping doesn't have back-relation
  // resolvedBy removed - User doesn't have back-relation defined
  
  createdAt               DateTime    @default(now())
  resolvedAt              DateTime?
  
  @@index([mappingId])
  @@index([severity])
  @@index([status])
  @@index([alertType])
}

