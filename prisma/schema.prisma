  studentId               String
  semester                String      // 1, 2, 3, 4, 5, 6, 7, 8, etc.
  academicYear            String      // 2023-24, 2024-25, etc.
  
  semesterGpa             Decimal?    @db.Decimal(4, 3)
  semesterCredits         Int
  creditsEarned           Int
  attemptedCredits        Int
  
  totalCreditsEarned      Int
  totalAttemptedCredits   Int
  cumulativeGpa           Decimal?    @db.Decimal(4, 3)
  
