# Prisma environment configuration example
# Copy this file to .env and fill in your actual values

# ============================================================================
# DATABASE CONNECTION
# ============================================================================

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://postgres:password@localhost:5432/department360?schema=public&sslmode=prefer"

# Connection pool settings
DATABASE_POOL_SIZE=20
DATABASE_POOL_IDLE_TIMEOUT=60

# ============================================================================
# PRISMA CONFIGURATION
# ============================================================================

# Enable verbose logging for debugging
PRISMA_LOG_QUERIES=false

# Database connection timeout (ms)
PRISMA_TIMEOUT=30000

# ============================================================================
# FIELD ENCRYPTION KEYS
# ============================================================================

# For encrypting sensitive fields (salary, SSN, etc.)
# Generate with: openssl rand -base64 32
FIELD_ENCRYPTION_KEY="your-256-bit-base64-encoded-key-here"

# ============================================================================
# ONEDRIVE INTEGRATION
# ============================================================================

# Microsoft Graph API credentials for OneDrive integration
ONEDRIVE_CLIENT_ID="your-client-id"
ONEDRIVE_CLIENT_SECRET="your-client-secret"
ONEDRIVE_TENANT_ID="common"
ONEDRIVE_REDIRECT_URI="http://localhost:3000/auth/callback/onedrive"

# ============================================================================
# AUTHENTICATION
# ============================================================================

# JWT secret for token signing
JWT_SECRET="your-jwt-secret-key-at-least-32-characters"

# MFA settings
MFA_WINDOW_SIZE=1
MFA_TIME_STEP=30

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# SMTP settings for email notifications
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@department360.edu"

# ============================================================================
# REDIS CACHE
# ============================================================================

# Redis connection for caching
REDIS_URL="redis://localhost:6379/0"

# Cache TTL in seconds
CACHE_TTL=3600

# ============================================================================
# LOGGING
# ============================================================================

# Log level: error, warn, info, debug
LOG_LEVEL="info"

# Audit log retention days
AUDIT_LOG_RETENTION=2555  # 7 years for FERPA compliance

# ============================================================================
# SECURITY
# ============================================================================

# CORS settings
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# FERPA mode (strict student privacy)
FERPA_MODE=true

# ============================================================================
# APPLICATION
# ============================================================================

# Environment
NODE_ENV="development"

# Port
PORT=3000

# API base URL
API_BASE_URL="http://localhost:3000"
API_PREFIX="/api"

# Application version
APP_VERSION="1.0.0"

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================

# Database seed in development
SEED_DATABASE=true

# Enable Prisma Studio on startup
ENABLE_PRISMA_STUDIO=false
